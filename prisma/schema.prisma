generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

enum StockLocation {
  SHOP
  GODOWN
}

enum SizeType {
  BIG
  SMALL
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  PARTIAL
  RECEIVED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  COMPLETED
  CANCELLED
  RETURNED
}

enum InventoryMovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  PURCHASE_RETURN
  SALES_RETURN
}

model Company {
  id          String   @id @default(cuid())

  name        String
  code        String   @unique

  logoUrl     String?  @map("logo_url")

  email       String?
  phone       String?

  address     String?

  city        String?
  state       String?
  country     String?

  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  users               User[]
  categories          Category[]
  brands              Brand[]
  suppliers           Supplier[]
  products            Product[]
  productVariants     ProductVariant[]

  purchaseOrders      PurchaseOrder[]
  purchaseOrderItems  PurchaseOrderItem[]
  salesOrders         SalesOrder[]
  salesOrderItems     SalesOrderItem[]

  stockTransfers      StockTransfer[]
  movements           InventoryMovement[]

  @@map("companies")
}

model User {
  id            String    @id @default(cuid())
  companyId     String?   @map("company_id")
  name          String?
  username      String?   @map("username")
  email         String?   @unique
  password      String?
  image         String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company       Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  accounts      Account[]
  sessions      Session[]

  purchaseOrders PurchaseOrder[] @relation("created_purchase_orders")
  salesOrders    SalesOrder[]     @relation("created_sales_orders")
  stockTransfers  StockTransfer[]  @relation("created_stock_transfers")
  movements       InventoryMovement[] @relation("created_movements")

  @@unique([companyId, username])
  @@index([companyId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")

  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  name       String   @map("name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Brand {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  name       String   @map("name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("brands")
}

model Supplier {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  name       String   @map("name")
  phone      String?
  email      String?
  address    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("suppliers")
}

model Product {
  id                   String   @id @default(cuid())
  companyId            String   @map("company_id")
  articleNo            String   @map("article_no")
  articleName          String   @map("article_name")

  brandId              String?  @map("brand_id")
  categoryId           String   @map("category_id")

  brand                Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category             Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sellingPrice         Decimal  @db.Decimal(10, 2) @map("selling_price")
  defaultPurchasePrice Decimal  @db.Decimal(10, 2) @map("default_purchase_price")

  imageUrl             String?  @map("image_url")
  isActive             Boolean  @default(true) @map("is_active")

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  variants             ProductVariant[]

  @@unique([companyId, articleNo])
  @@index([companyId])
  @@index([brandId])
  @@index([categoryId])
  @@map("products")
}

model ProductVariant {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  productId   String   @map("product_id")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  size        String   @map("size")
  color       String   @map("color")
  sizeType    SizeType @default(BIG) @map("size_type")

  shopQty     Int      @default(0) @map("shop_qty")
  godownQty   Int      @default(0) @map("godown_qty")
  minStock    Int      @default(5) @map("min_stock")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  purchaseItems PurchaseOrderItem[]
  salesItems    SalesOrderItem[]
  transfers     StockTransfer[]
  movements     InventoryMovement[]

  @@unique([companyId, productId, size, color, sizeType])
  @@index([companyId])
  @@index([productId])
  @@map("product_variants")
}

model PurchaseOrder {
  id           String             @id @default(cuid())
  companyId    String             @map("company_id")
  orderNo      String             @map("order_no")

  supplierId   String             @map("supplier_id")
  supplier     Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById  String?            @map("created_by_id")
  createdBy    User?              @relation("created_purchase_orders", fields: [createdById], references: [id], onDelete: SetNull)

  orderDate    DateTime           @default(now()) @map("order_date")
  expectedDate DateTime?          @map("expected_date")
  status       PurchaseOrderStatus @default(PENDING)

  totalAmount  Decimal            @db.Decimal(10, 2) @default(0) @map("total_amount")
  note         String?

  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  items        PurchaseOrderItem[]

  @@unique([companyId, orderNo])
  @@index([companyId])
  @@index([supplierId])
  @@index([createdById])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String   @id @default(cuid())
  companyId          String   @map("company_id")
  purchaseOrderId    String   @map("purchase_order_id")
  variantId          String   @map("variant_id")

  purchaseOrder      PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant            ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  orderedQty         Int      @map("ordered_qty")
  receivedQty        Int      @default(0) @map("received_qty")

  unitPurchasePrice  Decimal  @db.Decimal(10, 2) @map("unit_purchase_price")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  movements          InventoryMovement[] @relation("purchase_item_movements")

  @@index([companyId])
  @@index([purchaseOrderId])
  @@index([variantId])
  @@map("purchase_order_items")
}

model SalesOrder {
  id           String           @id @default(cuid())
  companyId    String           @map("company_id")
  invoiceNo    String           @map("invoice_no")

  createdById  String?          @map("created_by_id")
  createdBy    User?            @relation("created_sales_orders", fields: [createdById], references: [id], onDelete: SetNull)

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  soldAt      DateTime         @default(now()) @map("sold_at")
  status      SalesOrderStatus @default(COMPLETED)

  totalAmount Decimal          @db.Decimal(10, 2) @default(0) @map("total_amount")
  note        String?

  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  items       SalesOrderItem[]

  @@unique([companyId, invoiceNo])
  @@index([companyId])
  @@index([createdById])
  @@map("sales_orders")
}

model SalesOrderItem {
  id            String   @id @default(cuid())
  companyId      String   @map("company_id")
  salesOrderId  String   @map("sales_order_id")
  variantId     String   @map("variant_id")

  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2) @map("unit_price")
  totalPrice    Decimal  @db.Decimal(10, 2) @map("total_price")

  soldFrom      StockLocation @default(SHOP) @map("sold_from")

  createdAt     DateTime @default(now()) @map("created_at")

  movements     InventoryMovement[] @relation("sales_item_movements")

  @@index([companyId])
  @@index([salesOrderId])
  @@index([variantId])
  @@map("sales_order_items")
}

model StockTransfer {
  id            String   @id @default(cuid())
  companyId      String   @map("company_id")
  transferNo    String   @map("transfer_no")

  variantId     String   @map("variant_id")
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fromLocation  StockLocation @map("from_location")
  toLocation    StockLocation @map("to_location")
  quantity      Int

  createdById   String?  @map("created_by_id")
  createdBy     User?    @relation("created_stock_transfers", fields: [createdById], references: [id], onDelete: SetNull)

  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  movements     InventoryMovement[]

  @@unique([companyId, transferNo])
  @@index([companyId])
  @@index([variantId])
  @@index([createdById])
  @@map("stock_transfers")
}

model InventoryMovement {
  id                  String                @id @default(cuid())
  companyId            String                @map("company_id")
  variantId            String                @map("variant_id")

  variant              ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Restrict)
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  movementType         InventoryMovementType @map("movement_type")
  quantity             Int
  location             StockLocation

  purchaseOrderItemId   String?              @map("purchase_order_item_id")
  purchaseOrderItem     PurchaseOrderItem?   @relation("purchase_item_movements", fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)

  salesOrderItemId      String?              @map("sales_order_item_id")
  salesOrderItem        SalesOrderItem?      @relation("sales_item_movements", fields: [salesOrderItemId], references: [id], onDelete: SetNull)

  stockTransferId       String?              @map("stock_transfer_id")
  stockTransfer         StockTransfer?       @relation(fields: [stockTransferId], references: [id], onDelete: SetNull)

  createdById           String?              @map("created_by_id")
  createdBy             User?                @relation("created_movements", fields: [createdById], references: [id], onDelete: SetNull)

  note                  String?
  createdAt             DateTime             @default(now()) @map("created_at")

  @@index([companyId])
  @@index([variantId])
  @@index([movementType])
  @@index([location])
  @@map("inventory_movements")
}